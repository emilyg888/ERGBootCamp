# Concept2 Logbook API token
C2_API_TOKEN=your_concept2_token_here

# OpenAI-compatible key — used by the local Ollama server
# Ollama doesn't require a real key; set anything non-empty
OPENAI_API_KEY=ollama

# Discord webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/xxxxx

# Garmin Connect (optional)
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your_garmin_password
