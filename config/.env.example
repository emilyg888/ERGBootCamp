# Concept2 Logbook API token
C2_API_TOKEN=your_concept2_token_here

# OpenAI-compatible key — used by LMStudio local server
# LMStudio doesn't require a real key; set anything non-empty
OPENAI_API_KEY=lm-studio

# Twilio credentials (WhatsApp Sandbox)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+YOURPHONENUMBER

# Garmin Connect (optional)
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your_garmin_password
